
unameOut="$(uname -s)"
case "${unameOut}" in
    Linux*)     machine=Linux;;
    Darwin*)    machine=Mac;;
    CYGWIN*)    machine=Cygwin;;
    MINGW*)     machine=MinGw;;
    MSYS_NT*)   machine=MSys;;
    *)          machine="UNKNOWN:${unameOut}"
esac

SAR_SCRIPT_ROOT=${SAR_SCRIPT_ROOT:-"$HOME/scripts"}

export PATH="$PATH:${SAR_SCRIPT_ROOT}/dev"
export PATH="$PATH:${SAR_SCRIPT_ROOT}/net"
export PATH="$PATH:${SAR_SCRIPT_ROOT}/util"

if [ $machine = "Mac" ]; then
    export PATH="$PATH:${SAR_SCRIPT_ROOT}/mac"
fi
